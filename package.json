{
  "name": "eslint-config-decent",
  "version": "4.2.17",
  "description": "A decent ESLint configuration",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./oxlint": {
      "import": {
        "types": "./dist/oxlint.d.ts",
        "default": "./dist/oxlint.mjs"
      },
      "require": {
        "types": "./dist/oxlint.d.cts",
        "default": "./dist/oxlint.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "tsgo --noEmit --skipLibCheck",
    "lint:markdown": "prettier --write '**/*.md' '!**/node_modules/**' '!**/dist/**' && markdownlint '**/*.md' --ignore '**/node_modules/**' --ignore '**/dist/**' --config=.github/linters/.markdown-lint.yml --fix",
    "lint:code": "eslint --fix",
    "prelint": "npm run build",
    "lint": "run-p lint:*",
    "lint-staged": "lint-staged",
    "beta": "npm publish --tag beta",
    "prepublishOnly": "pinst --disable",
    "postpublish": "pinst --enable",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write --cache",
      "markdownlint --config=.github/linters/.markdown-lint.yml --fix"
    ],
    "*.{json5,yml}": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,ts}": [
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgeurts/eslint-config-decent.git"
  },
  "keywords": [
    "eslint",
    "oxlint",
    "config",
    "decent"
  ],
  "author": "Jim Geurts <jim@biacreations.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jgeurts/eslint-config-decent/issues"
  },
  "homepage": "https://github.com/jgeurts/eslint-config-decent#readme",
  "engines": {
    "node": ">=22.13.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0",
    "oxlint": ">=1.53.0",
    "oxlint-tsgolint": ">=0.1.0",
    "oxlint-plugin-eslint": ">=1.52.0",
    "@stylistic/eslint-plugin": ">=5.0.0",
    "@vitest/eslint-plugin": ">=1.0.0",
    "eslint-plugin-jsdoc": ">=62.0.0",
    "eslint-plugin-react": ">=7.0.0",
    "eslint-plugin-security": ">=4.0.0",
    "eslint-plugin-testing-library": ">=7.0.0",
    "eslint-plugin-unicorn": ">=63.0.0",
    "typescript": ">=5.5.0"
  },
  "peerDependenciesMeta": {
    "oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    },
    "oxlint-plugin-eslint": {
      "optional": true
    },
    "@stylistic/eslint-plugin": {
      "optional": true
    },
    "@vitest/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-jsdoc": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-security": {
      "optional": true
    },
    "eslint-plugin-testing-library": {
      "optional": true
    },
    "eslint-plugin-unicorn": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@vitest/eslint-plugin": "1.6.13",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.8.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-testing-library": "7.16.1",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "typescript-eslint": "8.57.1"
  },
  "devDependencies": {
    "@eslint/config-helpers": "0.5.3",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@swc/core": "1.15.18",
    "@types/node": ">=22",
    "@typescript/native-preview": "7.0.0-dev.20260321.1",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "eslint": "10.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli": "0.48.0",
    "npm-run-all2": "8.0.4",
    "oxlint": "1.56.0",
    "pinst": "3.0.0",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "unbuild": "3.6.1"
  },
  "overrides": {
    "eslint-plugin-import-x": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    },
    "eslint-plugin-promise": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    },
    "eslint-plugin-testing-library": {
      "eslint": "$eslint"
    }
  }
}
